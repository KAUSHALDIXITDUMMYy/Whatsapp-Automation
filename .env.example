# Server (copy to server/.env or export before running)
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_crm
REDIS_URL=redis://127.0.0.1:6379
# Dev-only on Windows without Redis: outbound WhatsApp runs inline (recommended locally).
SKIP_REDIS=true
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_JWT_SECRET=change-me-admin-secret
CORS_ORIGIN=http://localhost:5173

# Meta WhatsApp Cloud API (leave empty for full dry-run: sends + template submit/sync simulated)
# META_GRAPH_VERSION=v22.0
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
# Any random string you choose; must match the token you enter in Meta Webhooks setup.
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-verify-token

# Seed admin (npm run db:seed in /server)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminadmin

# Platform WhatsApp template names (upload these in Meta manually — see docs/PLATFORM_TEMPLATES.md)
META_TEMPLATE_WELCOME=cable_welcome_onboard
META_TEMPLATE_RECHARGE=cable_recharge_reminder
