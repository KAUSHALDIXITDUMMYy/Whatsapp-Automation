# Server (copy to server/.env or export before running)
PORT=4000
DATABASE_URL=postgresql://neondb_owner:npg_rVNEjnYt48ki@ep-sparkling-voice-anrkebfe-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
REDIS_URL=redis://127.0.0.1:6379
# Dev-only if you cannot run Redis locally (e.g. Windows): outbound WhatsApp runs inline, no queue.
# SKIP_REDIS=true
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_JWT_SECRET=change-me-admin-secret
CORS_ORIGIN=http://localhost:5173

# Optional: Twilio WhatsApp (leave empty for dry-run sends)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (recommended)
# META_GRAPH_VERSION=v22.0
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# Any random string you choose; must match the token you enter in Meta Webhooks setup.
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-verify-token

# Seed admin (npm run db:seed in /server)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminadmin

# Basic plan: max saved message templates (Pro = unlimited)
BASIC_MAX_TEMPLATES=5
