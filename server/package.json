{
  "name": "whatsapp-crm-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate-templates": "tsx src/db/applyTemplateSubmissionsMigration.ts",
    "db:migrate-dashboard-reminders": "tsx src/db/applyVendorDashboardRemindersMigration.ts",
    "db:migrate-content-types": "tsx src/db/applyTemplateContentTypesMigration.ts",
